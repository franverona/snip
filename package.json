{
  "name": "snip",
  "description": "Self-hosted URL shortener with click analytics",
  "private": true,
  "scripts": {
    "dev": "TURBO_TELEMETRY_DISABLED=1 turbo dev",
    "build": "TURBO_TELEMETRY_DISABLED=1 turbo build",
    "migrate": "TURBO_TELEMETRY_DISABLED=1 turbo migrate",
    "seed": "TURBO_TELEMETRY_DISABLED=1 turbo seed",
    "lint": "TURBO_TELEMETRY_DISABLED=1 turbo lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test:api": "pnpm --filter api run test",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^10.0.1",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "turbo": "^2.8.20",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.57.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": "eslint --fix",
    "*.{ts,tsx,js,json,md,yaml,yml,css}": "prettier --write"
  },
  "packageManager": "pnpm@10.32.1"
}
