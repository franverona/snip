NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_TELEMETRY_DISABLED=1

# Optional: protect the dashboard with a password. When set, unauthenticated
# visitors are redirected to /login before they can access any page.
# DASHBOARD_PASSWORD=your-password

# Optional: the API key sent as "Authorization: Bearer <key>" on mutating
# requests (POST /urls, DELETE /urls/:slug). Must match API_KEY in apps/api.
# API_KEY=your-api-key
