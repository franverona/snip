PORT=3001
BASE_URL=http://localhost:3001

DATABASE_URL=postgresql://snip:snip@localhost:5432/snip
DATABASE_POOL_MAX=10

RATE_LIMIT_CREATE_PER_MINUTE=10      # POST /urls (strict)

# Origin allowed by CORS. Defaults to BASE_URL if unset.
# In production, set this to your web app's origin (e.g. https://snip.example.com).
CORS_ORIGIN=http://localhost:3000

IP_HASH_SECRET=ip-hash-super-secret

# Optional: require this key as "Authorization: Bearer <key>" on POST /urls and DELETE /urls/:slug.
# When unset, those endpoints are publicly accessible.
# API_KEY=your-api-key
